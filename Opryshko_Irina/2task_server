#define _WINSOCK_DEPRECATED_NO_WARNINGS 
#define _CRT_SECURE_NO_WARNINGS         

#include <WinSock2.h> 
#include <windows.h>  
#include <iostream>   
#include <string>     
#include <vector>     
#include <thread>     
#include <mutex>      
#include <sstream>    
#include <stdexcept>  
#include <cstdint>    
#include <ctime>      
