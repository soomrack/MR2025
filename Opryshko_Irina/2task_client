// Перечисление типов пакетов, которые понимает наш сервер на Raspberry Pi
enum class MessageType : uint32_t {
    Text = 1,        // Обычное сообщение для чата
    Connect = 2,     // Пакет регистрации (отправляем свой ник при входе)
    Disconnect = 3,  // Уведомление сервера о закрытии клиента
    LogRequest = 4,  // Команда "Дай мне логи"
    LogResponse = 5  // Ответ от сервера с текстом логов
};

// Заголовок сообщения — это "паспорт" пакета, всегда ровно 8 байт
struct MessageHeader {
    uint32_t type;   // Числовой код типа сообщения (из enum выше)
    uint32_t size;   // Сколько байт полезной информации (текста) идет следом
};

// Глобальные переменные (доступны из любой функции)
SOCKET clientSocket = INVALID_SOCKET; // Дескриптор сокета нашего соединения (изначально пустой)
bool connected = false;               // Флаг: установлена ли связь с сервером
bool running = true;                  // Флаг: работает ли программа клиента в целом
std::mutex coutMutex;                 // "Замок" для консоли, чтобы потоки не перебивали друг друга при выводе
std::string username;                 // Переменная для хранения имени текущего пользователя

// ============================================================
// УТИЛИТЫ (Вспомогательные функции)
