// Настройка консоли на поддержку русского языка и Эмодзи (UTF-8)
void setupConsole() {
    SetConsoleOutputCP(CP_UTF8); // Устанавливаем кодировку вывода в UTF-8
    SetConsoleCP(CP_UTF8);       // Устанавливаем кодировку ввода в UTF-8
}

// Процедура включения сетевого драйвера Windows
void initWinSock() {
    WSADATA wsa;                     // Структура для системной информации о WinSock
    WSAStartup(MAKEWORD(2, 2), &wsa); // Запуск WinSock версии 2.2
}

// Процедура выключения сети перед выходом
void cleanupWinSock() {
    WSACleanup(); // Освобождаем ресурсы сетевой подсистемы
}

// Функция получения текущего времени в текстовом формате ЧЧ:ММ:СС
std::string getCurrentTime() {
    time_t now = time(0);               // Берем текущее время в секундах
    struct tm timeinfo;                 // Структура для хранения разобранного времени
    localtime_s(&timeinfo, &now);       // Превращаем секунды в часы/минуты (безопасная версия для Windows)
    char buffer[80];                    // Временный буфер для текста
    strftime(buffer, sizeof(buffer), "%H:%M:%S", &timeinfo); // Записываем время в буфер по формату
    return std::string(buffer);         // Возвращаем результат как объект строки
}

// Функция поиска текстовых кодов и их замены на символы Эмодзи
std::string replaceEmoji(std::string text) {
    // Список пар: что ищем и на что меняем
    std::vector<std::pair<std::string, std::string>> emojis = {
        {":fire:", u8"🔥"}, {":smile:", u8"😄"}, {":sad:", u8"😢"}, {":heart:", u8"❤️"}, {":ok:", u8"👌"}
    };
    for (auto& e : emojis) { // Для каждой пары в списке...
        size_t pos;          // Переменная для хранения позиции найденного текста
        while ((pos = text.find(e.first)) != std::string::npos) // Пока находим код (например :fire:)...
            text.replace(pos, e.first.length(), e.second);      // Заменяем его на картинку
    }
    return text; // Возвращаем уже "красивый" текст
}

// ============================================================
// СЕТЕВОЙ ОБМЕН (Низкий уровень)
// ============================================================

// Функция гарантированной отправки (отправляет данные до последнего байта)
void sendAll(const char* data, int size) {
    int sent = 0; // Счетчик уже ушедших байт
    while (sent < size) { // Пока не отправили всё...
        int res = send(clientSocket, data + sent, size - sent, 0); // Системный вызов отправки
        if (res <= 0) throw std::runtime_error("send failed");     // Если ошибка — прерываемся
        sent += res; // Считаем, сколько отправилось в этой итерации
    }
}

// Функция гарантированного приема (ждет, пока не придет весь пакет целиком)
void recvAll(char* data, int size) {
    int received = 0; // Счетчик полученных байт
    while (received < size) { // Пока не получили нужный объем...
        int res = recv(clientSocket, data + received, size - received, 0); // Системный вызов приема
        if (res <= 0) throw std::runtime_error("recv failed");             // Если сервер отключился — ошибка
        received += res; // Добавляем полученное к общему счетчику
    }
}

