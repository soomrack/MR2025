#define _WINSOCK_DEPRECATED_NO_WARNINGS //вызов функции винсок  
#define _CRT_SECURE_NO_WARNINGS

#include <iostream>
#include <winsock2.h> //сетевые функции
#include <string> //удобная работа со строками

#pragma comment(lib, "ws2_32.lib") // во врмя сборки программы использовать файл вс2_32

int main() {
    std::cout << "=== TCP Message Client ===\n";

    // 1. Инициализация Winsock
    WSADATA wsaData; //пробуждение сети, структура всдата с названием всадата. бланк для сетевой системы 
    if (WSAStartup(MAKEWORD(2, 2), &wsaData) != 0) { // начало работы с вса с версией винсок 2 2, при поомщи указателя говорим какую структуру использовать
        std::cerr << "Failed to initialize Winsock. Error: " << WSAGetLastError() << std::endl;
        return 1;
    }

    // 2. Создание сокета
    SOCKET clientSocket = socket(AF_INET, SOCK_STREAM, 0); //сокет - дескриптор, функция сокет с 3 параметрами, семейство адресов, тсп-протокол, 
    if (clientSocket == INVALID_SOCKET) {
        std::cerr << "Failed to create socket. Error: " << WSAGetLastError() << std::endl;
        WSACleanup(); //прекращение работы с вса
        return 1;
    }

    // 3. Настройка адреса сервера
    sockaddr_in serverAddr;
    serverAddr.sin_family = AF_INET;
    serverAddr.sin_port = htons(8052);  // Порт сервера

    // Ввод IP-адреса сервера
    std::string serverIP;
    std::cout << "Enter server IP address (default: 127.0.0.1 for localhost): ";
    std::getline(std::cin, serverIP);

    if (serverIP.empty()) {
        serverIP = "192.168.43.14";
    }

    serverAddr.sin_addr.s_addr = inet_addr(serverIP.c_str()); //внутри структуры сервераддр найди пункт (вложенную структуру) в адресе с названием числом адреса и присвой значение ип, но в виде машинного кода

    // 4. Подключение к серверу
    std::cout << "Connecting to server " << serverIP << ":8052...\n";

    if (connect(clientSocket, (sockaddr*)&serverAddr, sizeof(serverAddr)) == SOCKET_ERROR) { //функция коннект с 3 аргументами хендл сокета, передача структуры со всей инфой об адресе, указываем сколько байт выделено под адрес, чтобы не считать лишнего
        std::cerr << "Connection failed. Error: " << WSAGetLastError() << std::endl; // функц возвращает результат подключ и сравниваем с сокет еррор
        std::cerr << "Make sure:\n";
        std::cerr << "1. Server is running\n";
        std::cerr << "2. Correct IP address\n";
        std::cerr << "3. Firewall allows connections on port 8052\n";
        closesocket(clientSocket);
        WSACleanup();
        return 1;
    }

    std::cout << "Connected to server successfully!\n\n";

    // 5. Получение приветственного сообщения
    char buffer[1024];
    memset(buffer, 0, sizeof(buffer)); //функция кот заполн память определенными символами, 3 арг: весь буффер заполнили 0 
   // recv(clientSocket, buffer, sizeof(buffer), 0); //функция принятия данных из сокета в буффер 
    //std::cout << "Server: " << buffer;

    // 6. Основной цикл отправки сообщений
    std::string userInput; // переменная с большим хранилищем, влезет сообщение больше 1024
    

    while (true) {
        // Ввод сообщения
        std::cout << "You: ";
        std::getline(std::cin, userInput);
        userInput += ".";
        userInput += "/n";

        // Отправка сообщения серверу
        send(clientSocket, userInput.c_str(), userInput.length(), 0); //отправляет через клиент сокет сообщение в формате с, точно знаем количество передаваемых символов

        // Проверка на команду выхода
        if (userInput == "quit" || userInput == "exit") {
            std::cout << "Disconnecting from server...\n";
            break;
        }

        // Получение ответа от сервера
        memset(buffer, 0, sizeof(buffer)); //очищаем буффер
        int bytesReceived = recv(clientSocket, buffer, sizeof(buffer), 0); //создаем переменную в которую запис то что услышали от сервера

        if (bytesReceived > 0) {
            std::cout << "Server: " << buffer;
            memset(buffer, 0, sizeof(buffer)); //очищаем буффер
         
        }
        else if (bytesReceived == 0) {
            std::cout << "Server closed the connection.\n";
            break;
        }
        else {
            std::cerr << "Receive error.\n";
            break;
        }
    }

    // 7. Завершение работы
    closesocket(clientSocket);
    WSACleanup();

    std::cout << "\nClient stopped. Press Enter to exit...\n";
    std::cin.get();

    return 0;
}
