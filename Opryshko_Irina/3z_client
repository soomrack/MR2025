}                            // Конец функции setupConsole

void initWinSock() {         // Функция инициализации сетевой подсистемы Windows
    WSADATA wsa;             // Структура, куда Windows запишет данные о текущей версии сокетов
    WSAStartup(MAKEWORD(2, 2), &wsa); // Запрашивает использование сетевой библиотеки Winsock версии 2.2
}                            // Конец функции initWinSock

void cleanupWinSock() {      // Функция деинициализации сетевой подсистемы Windows
