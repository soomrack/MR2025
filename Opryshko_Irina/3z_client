}                            // Конец функции cleanupWinSock

// ============================================================
// НИЗКОУРОВНЕВАЯ ОТПРАВКА 
// ============================================================

void sendAll(const char* data, int size) { // Функция гарантированной отправки ровно size байт в сеть
    int sent = 0;            // Счетчик фактически отправленных байт
    while (sent < size) {    // Цикл выполняется, пока не будут отправлены абсолютно все байты пакета
        int res = send(clientSocket, data + sent, size - sent, 0); // Пытаемся отправить оставшийся кусок данных
        if (res <= 0) throw std::runtime_error("send failed"); // Если res <= 0, значит произошел разрыв сети или ошибка
        sent += res;         // Сдвигаем указатель данных вперед на количество успешно отправленных байт
    }                        // Конец цикла отправки
}                            // Конец функции sendAll

void recvAll(char* data, int size) { // Функция гарантированного приема ровно size байт из сети
    int received = 0;        // Счетчик фактически принятых байт
    while (received < size) { // Цикл выполняется, пока буфер не заполнится до целевого размера size
        int res = recv(clientSocket, data + received, size - received, 0); // Пытаемся прочитать оставшийся кусок данных
        if (res <= 0) throw std::runtime_error("recv failed"); // Если res <= 0, сервер отключился или сеть упала
        received += res;     // Сдвигаем указатель буфера вперед на количество успешно прочитанных байт
    }                        // Конец цикла приема
}                            // Конец функции recvAll

// ============================================================
// Ввод имени пользователя
// ============================================================
std::string getUsername() {  // Функция валидации и получения никнейма пользователя
    std::string name;        // Локальная строка для временного хранения ввода
    while (true) {           // Бесконечный цикл, пока пользователь не введет корректное имя
        std::cout << "Enter your name (3-20 characters): "; // Запрос на ввод имени в консоль
        std::getline(std::cin, name); // Считываем всю строку целиком, включая возможные пробелы

        size_t first = name.find_first_not_of(" \t"); // Ищем индекс первого символа, который не является пробелом/табуляцией
        size_t last = name.find_last_not_of(" \t");   // Ищем индекс последнего символа, который не является пробелом/табуляцией
        if (first == std::string::npos || last == std::string::npos) { // Если строка состоит целиком из пробелов
            std::cout << "Name cannot be empty!\n"; // Выводим предупреждение
            continue;        // Возвращаемся в начало цикла ввода
        }                    // Конец проверки на пустую строку
        name = name.substr(first, last - first + 1); // Обрезаем (trim) пробелы с начала и с конца строки

        if (name.length() < 3) { // Проверка минимальной длины имени
            std::cout << "Name too short! Minimum 3 characters.\n"; // Выводим ошибку длины
            continue;        // На повторный круг ввода
        }                    // Конец проверки минимума
        if (name.length() > 20) { // Проверка максимальной длины имени
            std::cout << "Name too long! Maximum 20 characters.\n"; // Выводим ошибку переполнения
            continue;        // На повторный круг ввода
        }                    // Конец проверки максимума

        bool valid = true;   // Переменная-флаг валидности символов никнейма
        for (char c : name) { // Посимвольно перебираем очищенное имя
            if (!isalnum(c) && c != '_' && c != '-' && c != ' ') { // Разрешаем только буквы, цифры, пробел, подчёркивание и дефис
                valid = false; // Если встретили запрещенный символ, поднимаем флаг ошибки
                break;       // Прерываем проверку символов текущей строки
            }                // Конец проверки символа
        }                    // Конец цикла перебора символов
        if (!valid) {        // Если флаг валидности сбросился в false
            std::cout << "Name can only contain letters, numbers, spaces, underscores and hyphens!\n"; // Пишем правила
            continue;        // На повторный круг ввода
        }                    // Конец обработки ошибки спецсимволов

        return name;         // Если все проверки успешно пройдены, возвращаем очищенное имя
    }                        // Конец бесконечного цикла
}                            // Конец функции getUsername

std::string getCurrentTime() { // Функция генерации текущего времени в формате строки
    time_t now = time(0);    // Получаем текущее системное время в секундах (Unix-time)
    struct tm timeinfo;      // Создаем структуру для хранения разбитого по часам/минутам времени
    localtime_s(&timeinfo, &now); // Безопасно заполняем структуру локальным временем компьютера

    char buffer[80];         // Символьный буфер под будущую текстовую строку времени
    strftime(buffer, sizeof(buffer), "%H:%M:%S", &timeinfo); // Форматируем время из структуры в текст "ЧЧ:ММ:СС"
    return std::string(buffer); // Конвертируем char-массив в std::string и возвращаем из функции
}                            // Конец функции getCurrentTime

