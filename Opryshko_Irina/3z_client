std::string replaceEmoji(std::string text) { // Функция автозамены текстовых шорткодов на UTF-8 смайлики
    std::vector<std::pair<std::string, std::string>> emojis = { // Словарь пар: "текстовый тег" -> "реальный UTF-8 эмодзи"
        {":fire:", u8"🔥"},   // Заменяет строку :fire: на огонек
        {":smile:", u8"😄"},  // Заменяет строку :smile: на улыбку
        {":sad:", u8"😢"},    // Заменяет строку :sad: на грустный смайлик
        {":heart:", u8"❤️"},  // Заменяет строку :heart: на сердечко
        {":ok:", u8"👌"}       // Заменяет строку :ok: на жест "ОК"
    };                       // Конец инициализации вектора emojis

    for (auto& e : emojis) { // Перебираем каждую пару смайликов из нашего словаря
        size_t pos;          // Переменная для хранения позиции найденного тега в тексте
        while ((pos = text.find(e.first)) != std::string::npos) // Крутим цикл, пока в тексте находится текущий тег (например :fire:)
            text.replace(pos, e.first.length(), e.second); // Заменяем найденный кусок текста на соответствующий UTF-8 эмодзи
    }                        // Конец перебора словаря
    return text;             // Возвращаем измененный текст строки назад
}                            // Конец функции replaceEmoji

// ============================================================
// ПРИЁМ СООБЩЕНИЙ 
// ============================================================

void receiveLoop() {         // Фоновая функция (работает в отдельном потоке) для постоянного приема данных от сервера
    try {                    // Блок отлова сетевых ошибок и разрывов связи
        while (connected) {  // Работаем в бесконечном цикле, пока удерживается сетевое соединение
            MessageHeader header{}; // Создаем пустой заголовок пакета
            recvAll((char*)&header, sizeof(header)); // Ждем и читаем из сети строго первые 8 байт (тип и размер пакета)

            std::vector<char> data(header.size); // Выделяем динамический массив байт под размер полезной нагрузки пакета
            if (header.size > 0) { // Если сервер передал нам не пустой текст (размер payload больше 0)
                recvAll(data.data(), header.size); // Вычитываем из сокета оставшиеся header.size байт текста
            }                // Конец проверки размера данных

            std::string text(data.begin(), data.end()); // Превращаем массив принятых байт в стандартную С++ строку text

            if (header.type == static_cast<uint32_t>(MessageType::LogResponse)) { // Если от сервера пришел ответ на запрос логов/телеметрии
                std::lock_guard<std::mutex> lock(coutMutex); // Блокируем консоль мьютексом перед выводом, чтобы текст не перемешался
                // Красиво выводим данные, включая показания датчика линии
                if (text.rfind("LINE_VALUE:", 0) == 0) { // Если строка ответа начинается со спец-маркера "LINE_VALUE:" (команда /line)
                    std::cout << "\n[ROBOT] " << text << "\n> "; // Выводим данные датчика робота с префиксом и возвращаем приглашение к вводу
                }            // Конец обработки значения линии
                else {       // Если это ответ на команду общего запроса логов (/logs)
                    std::cout << "\n=== LOG RESPONSE ===\n" // Выводим красивую шапку ответа логов
                        << text // Печатаем сам текст логов, присланных Малинкой
                        << "====================\n> "; // Выводим закрывающий подвал и приглашение ввода
                }            // Конец вывода обычных логов
            }                // Конец обработки LogResponse
            else {           // Если пришел любой другой тип сообщения (например, обычный чат от других клиентов)
                std::lock_guard<std::mutex> lock(coutMutex); // Точно так же монопольно захватываем консоль
                std::cout << "\n" << text << "\n> "; // Просто выводим текст сообщения на новой строке и рисуем стрелочку ввода
            }                // Конец обработки прочих типов сообщений
        }                    // Конец цикла приема while
    }                        // Конец блока try
    catch (...) {            // Сюда управление переходит автоматически при любом сбое recv (например, выдернули кабель)
        std::lock_guard<std::mutex> lock(coutMutex); // Захватываем консоль для безопасного вывода аварийного сообщения
        std::cout << "\nDisconnected from server.\n> "; // Информируем пользователя о потере коннекта с сервером
        connected = false;   // Принудительно сбрасываем флаг активности соединения в false
        closesocket(clientSocket); // Закрываем дескриптор сокета, освобождая сетевой ресурс ОС
    }                        // Конец блока catch
}                            // Конец функции потока receiveLoop

// ============================================================
// ВЫСОКОУРОВНЕВАЯ ЛОГИКА 
// ============================================================

bool connectToServer(const std::string& ip, int port) { // Функция инициализации и создания подключения к серверу
    username = getUsername(); // Первым делом заставляем пользователя ввести валидный никнейм через консоль
    if (username.empty()) return false; // Защитная проверка: если имя пустое (сбой), выходим с флагом неудачи

    clientSocket = socket(AF_INET, SOCK_STREAM, IPPROTO_TCP); // Создаем потоковый TCP сокет под IPv4 адресацию
    if (clientSocket == INVALID_SOCKET) { // Проверяем, смогла ли операционная система выделить дескриптор сокета
        std::cout << "Socket creation failed.\n"; // Сообщаем о системной ошибке сокета
        return false;        // Выходим из функции с отказом
    }                    // Конец проверки создания сокета

    sockaddr_in addr{};      // Создаем структуру сетевого адреса и обнуляем её конфигурацию
    addr.sin_family = AF_INET; // Настраиваем семейство адресов как IPv4
    addr.sin_port = htons(port); // Конвертируем номер порта из человеческого формата в сетевой порядок байт (Big-Endian)
    addr.sin_addr.s_addr = inet_addr(ip.c_str()); // Переводим IP-адрес из текстового вида "X.X.X.X" в числовой двоичный формат

    if (connect(clientSocket, (sockaddr*)&addr, sizeof(addr)) == 0) { // Вызываем системную функцию сопряжения с сервером и проверяем на равенство 0 (успех)
        connected = true;    // Устанавливаем глобальный статус подключения в положение true

        try {                // Стартуем блок отправки приветственного пакета аутентификации никнейма
            std::string connectMsg = username; // Формируем полезную нагрузку пакета (просто передаем строку нашего имени)
            MessageHeader header{ static_cast<uint32_t>(MessageType::Connect), (uint32_t)connectMsg.size() }; // Собираем 8-байтный заголовок типа Connect
            sendAll((char*)&header, sizeof(header)); // Отправляем заголовок пакета серверу на Малинку
            sendAll(connectMsg.data(), connectMsg.size()); // Следом отправляем само имя пользователя

            std::thread(receiveLoop).detach(); // Создаем параллельный поток для приема ответов сервера и отсоединяем его (будет жить сам по себе)

            std::cout << "Connected to " << ip << ":" << port << " as '" << username << "'\n"; // Радуем пользователя успешным логом коннекта
            return true;     // Возвращаем true — соединение установлено и поток запущен
        }                    // Конец блока try авторизации никнейма
        catch (...) {        // Если на этапе первой отправки имени сеть рухнула
            std::cout << "Failed to send username.\n"; // Выводим ошибку в консоль
            closesocket(clientSocket); // Закрываем сокет
            connected = false; // Сбрасываем статус подключения
            return false;    // Возвращаем маркер неудачи
        }                    // Конец обработки исключения при авторизации
    }                        // Конец блока успешного выполнения connect

    std::cout << "Connection failed.\n"; // Сюда попадаем, если системный connect вернул ошибку (неверный IP, выключен сервер)
    return false;            // Возвращаем статус неудачи подключения
}                            // Конец функции connectToServer

void disconnectFromServer() { // Функция корректного ручного разрыва связи с сервером
    if (connected) {         // Проверяем, подключены ли мы вообще в данный момент
        try {                // Попытка вежливо предупредить сервер о том, что мы уходим
            std::string disconnectMsg = username; // Формируем нагрузку пакета (наше имя для логов сервера)
            MessageHeader header{ static_cast<uint32_t>(MessageType::Disconnect), (uint32_t)disconnectMsg.size() }; // Создаем заголовок пакета Disconnect
            sendAll((char*)&header, sizeof(header)); // Засылаем заголовок на Малинку
            sendAll(disconnectMsg.data(), disconnectMsg.size()); // Засылаем тело сообщения
        }                    // Конец блока вежливого отключения
        catch (...) {}       // Если сеть уже и так упала, то просто игнорируем ошибки отправки уведомления

        connected = false;   // Сбрасываем глобальный флаг соединения
        closesocket(clientSocket); // Закрываем сокет со стороны Windows
        std::cout << "Disconnected from server.\n"; // Логируем локальное отключение в консоли клиента
    }                        // Конец проверки условия connected
}                            // Конец функции disconnectFromServer

void sendMessage(const std::string& input) { // Высокоуровневая функция сборки и отправки чат-сообщения
    std::string timeStr = getCurrentTime(); // Получаем актуальную строку времени "ЧЧ:ММ:СС"
    std::string processedContent = replaceEmoji(input); // Прогоняем сырой текст через парсер смайликов (:fire: -> 🔥)

    std::string fullMessage = "[" + username + " " + timeStr + "] " + processedContent; // Склеиваем финальную чат-строку с ником и временем

    MessageHeader header{ static_cast<uint32_t>(MessageType::Text), (uint32_t)fullMessage.size() }; // Собираем заголовок сетевого пакета типа Text

    sendAll((char*)&header, sizeof(header)); // Отправляем 8 байт заголовка в сокет
    sendAll(fullMessage.data(), fullMessage.size()); // Отправляем саму сформированную строку сообщения
}                            // Конец функции sendMessage

bool spam(const std::string& input) { // Функция автоматического повтора сообщений (команда /spam <кол-во> <текст>)
    if (!connected) {        // Проверяем, есть ли связь с сервером
        std::cout << "Not connected.\n"; // Если связи нет, спамить нельзя
        return false;        // Выходим из функции
    }                        // Конец проверки связи

    std::stringstream ss(input); // Передаем входную команду в строковый поток для парсинга аргументов
    std::string cmd;         // Переменная под саму команду (туда запишется "/spam")
    int count;               // Переменная под число повторений
    std::string message;     // Переменная под текст сообщения для спама

    ss >> cmd >> count;      // Извлекаем из потока сначала слово "/spam", затем считываем число повторов
    std::getline(ss, message); // Забираем всё оставшееся до конца строки как текст сообщения

    if (!message.empty() && message[0] == ' ') // Отрезаем лишний начальный пробел перед текстом, если он остался после парсинга числа
        message = message.substr(1); // Перезаписываем строку без первого символа

    for (int i = 0; i < count; i++) { // Запускаем цикл спам-отправки ровно count раз
        try {                // Блок отслеживания разрыва сети во время спама
            if (i > 0) std::this_thread::sleep_for(std::chrono::milliseconds(100)); // Засыпаем на 100 мс между итерациями (кроме первой), чтобы не забить буфер сервера

            std::string spamMsg = message; // Создаем временную копию сообщения
            if (count > 1) { // Если сообщений больше одного, добавляем красивый префикс нумерации
                spamMsg = "[" + std::to_string(i + 1) + "/" + std::to_string(count) + "] " + message; // Пример формата: "[1/5] привет"
            }                // Конец сборки префикса нумерации

            sendMessage(spamMsg); // Вызываем базовую функцию отправки текстового сообщения в сеть
        }                    // Конец блока try спама
        catch (...) {        // Если сеть оборвалась прямо посреди отправки цикла спама
            std::cout << "Spam interrupted.\n"; // Сообщаем пользователю, что спам прерван
            break;           // Аварийно выходим из цикла отправки
        }                    // Конец блока отлова исключения спама
    }                        // Конец цикла спама
    return true;             // Успешное завершение работы функции спама
}                            // Конец функции spam

