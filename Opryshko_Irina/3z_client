void runClientEventLoop() {  // Главная функция обработки ввода пользователя (Event Loop клиента)
    std::string input;       // Строка, куда считывается всё, что пишет юзер в консоль

    while (running) {        // Главный цикл программы, работает пока флаг running равен true
        std::cout << "> ";   // Рисуем указатель приглашения к вводу команды или сообщения
        std::getline(std::cin, input); // Ждем нажатия Enter и считываем всю строку ввода целиком
        if (input.empty()) continue; // Защита: если юзер просто нажал Enter, проскакиваем на следующую итерацию цикла

        if (input.rfind("/connect", 0) == 0) { // Проверяем, начинается ли введенная строка с команды "/connect"
            if (connected) { // Защита: проверяем, если мы уже подключены к какому-то серверу
                std::cout << "Already connected.\n"; // Выводим предупреждение, что повторный коннект запрещен
                continue;    // Переходим в начало цикла ввода
            }                // Конец проверки дубликата коннекта
            std::stringstream ss(input); // Запихиваем строку ввода в поток для парсинга аргументов
            std::string cmd, ip; // Объявляем переменные под команду и целевой IP адрес
            int port;        // Объявляем переменную под номер порта сервера
            ss >> cmd >> ip >> port; // Извлекаем по очереди: "/connect", затем строку IP, затем число порта
            connectToServer(ip, port); // Вызываем функцию установления связи с полученными параметрами
        }                    // Конец обработки команды /connect
        else if (input == "/quit") { // Проверяем, совпадает ли ввод строго со словом "/quit"
            disconnectFromServer(); // Безопасно отключаемся от Малинки, сокет закрывается, но программа работает дальше
        }                    // Конец обработки команды /quit
        else if (input == "/exit") { // Проверяем, совпадает ли ввод строго со словом "/exit"
            running = false; // Опускаем флаг главного цикла в false (это приведет к завершению функции runClientEventLoop)
            disconnectFromServer(); // Автоматически рвем соединение с сервером перед окончательным выходом
        }                    // Конец обработки команды /exit
        else if (input.rfind("/spam", 0) == 0) { // Проверяем, начинается ли введенная строка с тега "/spam"
            spam(input);     // Передаем строку в функцию спама для дальнейшего разбора аргументов и рассылки пакетов
        }                    // Конец обработки команды /spam
        else if (input == "/help") { // Проверяем, совпадает ли ввод строго со словом "/help"
            printHelp();     // Вызываем функцию печати списка доступных команд
        }                    // Конец обработки команды /help
        // --- НОВАЯ КОМАНДА ДЛЯ ЗАПРОСА ДАТЧИКА ЛИНИИ ---
        else if (input == "/line") { // Проверяем, ввел ли пользователь команду опроса датчика робота "/line"
            if (!connected) { // Защита: проверяем, есть ли вообще связь с сервером Малинки
                std::cout << "Not connected.\n"; // Выводим ошибку отсутствия сети
                continue;    // На следующую итерацию цикла ввода
            }                // Конец проверки связи для датчика
            std::string request = "GET_LINE"; // Формируем строку-запрос, которую ожидает увидеть C++ сервер на Малинке
            MessageHeader header{ // Собираем сетевой заголовок пакета
                static_cast<uint32_t>(MessageType::LogRequest), // Указываем тип LogRequest (запрос данных)
                (uint32_t)request.size() // Прописываем размер текстовой команды "GET_LINE"
            };               // Конец инициализации заголовка
            try {            // Блок отслеживания ошибок отправки запроса датчика
                sendAll((char*)&header, sizeof(header)); // Публикуем 8 байт заголовка в сокет сети
                sendAll(request.data(), request.size()); // Следом отсылаем саму строковую команду "GET_LINE"
            }                // Конец блока try отправки
            catch (...) {    // Отработка внезапного падения сети в момент запроса
                std::cout << "Failed to send line sensor request.\n"; // Печатаем ошибку отправки запроса датчика
            }                // Конец блока catch
        }                    // Конец обработки команды /line
        // --- СТАНДАРТНЫЙ ЗАПРОС ЛОГОВ ---
        else if (input.rfind("/logs", 0) == 0) { // Проверяем, начинается ли ввод с вызова выгрузки логов "/logs"
            if (!connected) { // Проверяем статус сетевого подключения к серверу
                std::cout << "Not connected.\n"; // Сообщаем, что без сети логи стянуть нельзя
                continue;    // Возврат к началу цикла ввода
            }                // Конец проверки связи для логов

            std::string request; // Переменная для хранения внутренней текстовой команды, понятной серверу
            if (input == "/logs server")        request = "SERVER"; // Если юзер написал "/logs server", серверу шлем команду "SERVER"
            else if (input == "/logs board")    request = "BOARD";  // Если юзер написал "/logs board", серверу шлем команду "BOARD"
            else if (input == "/logs sensor")   request = "SENSOR"; // Если юзер написал "/logs sensor", серверу шлем команду "SENSOR"
            else if (input == "/logs all")      request = "ALL";    // Если юзер написал "/logs all", серверу шлем команду "ALL"
            else if (input == "/logs warnings") request = "WARNINGS"; // Если юзер написал "/logs warnings", серверу шлем команду "WARNINGS"
            else if (input.rfind("/logs last ", 0) == 0) { // Проверяем, запрошен ли временной интервал (например, "/logs last 5")
                request = "LAST " + input.substr(11); // Вырезаем цифру минут (все что после 11-го символа) и склеиваем в команду вида "LAST 5"
            }                // Конец проверки временного интервала логов
            else {           // Если пользователь написал команду некорректно (например, просто "/logs мусор")
                std::cout << "Usage:\n/logs <server|board|sensor|all|warnings>\n/logs last <minutes>\n"; // Выводим подсказку по синтаксису логов
                continue;    // Пропускаем текущую итерацию цикла, возвращаясь к вводу
            }                // Конец обработки неверного синтаксиса

            MessageHeader header{ // Создаем заголовок сетевого пакета запроса логов
                static_cast<uint32_t>(MessageType::LogRequest), // Ставим тип LogRequest (запрос информации)
                (uint32_t)request.size() // Передаем точный размер нашей текстовой подкоманды (например, размера строки "SENSOR")
            };               // Конец инициализации заголовка пакета логов

            try {            // Попытка отправить пакет запроса логов в сеть
                sendAll((char*)&header, sizeof(header)); // Посылаем 8 байт структуры заголовка логов
                sendAll(request.data(), request.size()); // Посылаем строку-аргумент команды логов
            }                // Конец блока try отправки запроса логов
            catch (...) {    // Сюда попадем, если в момент отправки пропал контакт с Малинкой
                std::cout << "Failed to send log request.\n"; // Выводим уведомление о сбое отправки пакета логов
            }                // Конец блока catch
        }                    // Конец обработки команды /logs
        // ОБЫЧНЫЙ ТЕКСТ
        else {               // Если строка ввода не совпала ни с одной из известных команд (начинающихся со знака "/")
            if (!connected) { // Проверяем, подключены ли мы, прежде чем пытаться слать текст в чат
                std::cout << "Not connected.\n"; // Пишем, что отправка обычного сообщения в пустоту невозможна
                continue;    // Возвращаемся в начало цикла ввода
            }                // Конец проверки связи для обычного сообщения
            sendMessage(input); // Вызываем функцию сборки сообщения (добавление времени, ника, смайликов) и отправки его в сеть чата
        }                    // Конец обработки обычного текста чата
    }                        // Конец глобального цикла while(running)
}                            // Конец функции runClientEventLoop

int main() {                 // Главная точка входа в приложение С++ клиента Windows
    setupConsole();          // Конфигурируем вывод консоли под UTF-8 (для правильного отображения русских букв и эмодзи)
    initWinSock();           // Инициализируем сетевую подсистему сокетов WSA в Windows (загружаем Ws2_32.dll в память)

    std::cout << "Messenger client started.\n"; // Приветственный лог о старте клиентской программы чата/управления
    printHelp();             // Сразу выводим юзеру подсказку по всем доступным командам (/connect, /line и т.д.)

    runClientEventLoop();    // Передаем управление в бесконечный цикл обработки ввода (программа зависает тут до команды /exit)

    cleanupWinSock();        // Сюда попадаем после выхода из цикла. Выгружаем библиотеку Winsock и освобождаем ресурсы сети
    return 0;                // Завершаем выполнение функции main с кодом возврата 0 (программа закрылась успешно)
}                            // Конец функции main
