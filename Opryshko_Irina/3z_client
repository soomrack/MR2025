enum class MessageType : uint32_t { // Перечисление типов пакетов, занимающее строго 4 байта (uint32_t)
    Text = 1,                       // Тип 1: Обычное текстовое сообщение в чат
    Connect = 2,                    // Тип 2: Запрос на регистрацию имени на сервере
    Disconnect = 3,                 // Тип 3: Уведомление сервера о безопасном выходе
    LogRequest = 4,                 // Тип 4: Запрос логов или телеметрии датчика (/logs, /line)
    LogResponse = 5                 // Тип 5: Ответ от сервера с текстовыми логами или данными датчика
};                                  // Конец перечисления MessageType

// Заголовок сообщения (строго 8 байт, без выравнивания)
#pragma pack(push, 1)        // Включает упаковку структур с выравниванием в 1 байт (убирает пустые "дыры" в памяти)
struct MessageHeader {       // Структура фиксированного заголовка сетевого пакета
    uint32_t type;           // 4 байта: Код типа сообщения из перечисления MessageType
    uint32_t size;           // 4 байта: Размер полезной текстовой нагрузки (payload), идущей следом
};                           // Конец структуры MessageHeader
#pragma pack(pop)            // Возвращает стандартное выравнивание памяти компилятора

struct TextMessage {         // Вспомогательная структура для разбора текстовых сообщений
    std::string username;    // Строка для хранения имени отправителя
    std::string timestamp;   // Строка для хранения времени отправки
    std::string content;     // Строка для хранения самого текста сообщения
};                           // Конец структуры TextMessage

// Глобальные переменные
SOCKET clientSocket = INVALID_SOCKET; // Дескриптор сокета клиента, по умолчанию инициализируется как некорректный
bool connected = false;               // Флаг: подключены ли мы в данный момент к серверу (true/false)
bool running = true;                  // Флаг: работает ли главное приложение (при false клиент завершает работу)
std::mutex coutMutex;                 // Мьютекс для защиты потока вывода std::cout от одновременной записи из разных потоков
std::string username;                 // Глобальная строка, хранящая имя текущего пользователя

