    std::cout << "/logs <type>          - Get logs (server/board/sensor/all/warnings/last <min>)\n"; // Инструкция для выгрузки логов системы
    std::cout << "/spam <count> <msg>   - Send a message multiple times\n"; // Инструкция для спам-команды
    std::cout << "/quit                  - Disconnect from server\n"; // Инструкция для отключения без закрытия окна
    std::cout << "/exit                  - Close client application\n"; // Инструкция для полного выхода и закрытия консоли
